# ============================================
# CONFIGURACIÓN PARA ONBOARDING & ESTIMADOR IA
# ============================================

# Google AI Studio - API Key para Gemini
# Obtener en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Upstash Redis - Para almacenar proyectos
# Obtener en: https://console.upstash.com/ o Vercel Marketplace → Redis
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Admin Token para acceder a /api/projects (protección simple)
ADMIN_TOKEN=your_secure_random_token_here

# Opcional: Para notificaciones por email (Resend, SendGrid, etc.)
# RESEND_API_KEY=re_...
