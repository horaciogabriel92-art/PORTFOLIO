rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Permitir lectura pública de logos de ejemplo
    match /example_logos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Logos subidos por usuarios - privados
    match /user_logos/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Mockups generados por IA
    match /mockups/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Por defecto, requerir autenticación
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
